# Production Environment Variables Template

# Copy this file and configure for your production environment
# DO NOT commit the actual .env file with real credentials

# ============================================
# API GATEWAY
# ============================================
PORT=3000
API_KEY=your-strong-production-api-key-here-change-this
TENANT_SERVICE_URL=http://tenant-service.railway.internal:3001
NODE_ENV=production

# ============================================
# TENANT SERVICE
# ============================================
# PORT=3001
# DATABASE_URL=postgresql://user:password@host:5432/database
# AMQP_URL=amqps://user:password@host/vhost
# NODE_ENV=production

# ============================================
# DB PROVISIONER SERVICE
# ============================================
# DATABASE_URL=postgresql://user:password@host:5432/database
# AMQP_URL=amqps://user:password@host/vhost
# NODE_ENV=production

# ============================================
# DNS PROVISIONER SERVICE
# ============================================
# AMQP_URL=amqps://user:password@host/vhost
# NODE_ENV=production

# ============================================
# CREDENTIALS SERVICE
# ============================================
# DATABASE_URL=postgresql://user:password@host:5432/database
# AMQP_URL=amqps://user:password@host/vhost
# NODE_ENV=production

# ============================================
# BILLING SERVICE
# ============================================
# AMQP_URL=amqps://user:password@host/vhost
# NODE_ENV=production
# STRIPE_SECRET_KEY=sk_live_your_stripe_key_here

# ============================================
# NOTIFICATION SERVICE
# ============================================
# AMQP_URL=amqps://user:password@host/vhost
# NODE_ENV=production
# SENDGRID_API_KEY=your_sendgrid_api_key_here
# FROM_EMAIL=noreply@yourdomain.com

# ============================================
# SHARED DATABASE (PostgreSQL)
# ============================================
# Provided by Railway automatically as DATABASE_URL
# Format: postgresql://user:password@host:port/database

# ============================================
# MESSAGE QUEUE (RabbitMQ)
# ============================================
# Get this from CloudAMQP or your RabbitMQ provider
# Format: amqps://user:password@host/vhost

# ============================================
# REDIS (Optional - for caching)
# ============================================
# REDIS_URL=redis://user:password@host:port

# ============================================
# LOGGING
# ============================================
# LOG_LEVEL=info
# PRETTY_PRINT=false

# ============================================
# SECURITY
# ============================================
# CORS_ORIGIN=https://yourdomain.com
# RATE_LIMIT_TTL=60
# RATE_LIMIT_MAX=100
